# Faultdesk Service Environment Variables

# Azure Voice Live API
VOICE_LIVE_ENDPOINT=https://your-region.api.cognitive.microsoft.com/voice
VOICE_LIVE_API_KEY=your_voice_live_api_key_here

# Azure OpenAI / Foundry
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_MODEL=gpt-4o-realtime-preview

# External APIs (Mock or Real)
SF113_API_URL=http://localhost:9001/api
CULTAS_API_URL=http://localhost:9002/api
AI_SEARCH_ENDPOINT=https://your-search-service.search.windows.net
AI_SEARCH_API_KEY=your_search_api_key_here

# Service Configuration
HOST=0.0.0.0
PORT=8001
LOG_LEVEL=INFO

# Voice Configuration
VOICE_NAME=ja-JP-NanamiNeural
VOICE_TEMPERATURE=0.7
TURN_DETECTION_THRESHOLD=0.5

# Call Logs
CALL_LOGS_DIR=./logs/calls
