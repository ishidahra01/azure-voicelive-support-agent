# Faultdesk Service Environment Variables

# Azure Voice Live API
VOICE_LIVE_ENDPOINT=https://your-region.api.cognitive.microsoft.com/voice
# Leave blank to use Microsoft Entra ID via DefaultAzureCredential.
VOICE_LIVE_API_KEY=
VOICE_LIVE_MODEL=gpt-realtime

# Microsoft Foundry for the MAF skill agent. Prefer this when using a Foundry project.
FOUNDRY_PROJECT_ENDPOINT=
FOUNDRY_MODEL=
# Enables dynamic file-based Agent Skills via SkillsProvider (load_skill/read_skill_resource).
MAF_USE_SKILLS_PROVIDER=true

# Azure OpenAI fallback for the MAF skill agent when FOUNDRY_PROJECT_ENDPOINT is blank.
# Leave AZURE_OPENAI_API_KEY blank to use Microsoft Entra ID via DefaultAzureCredential.
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_MODEL=gpt-4o

# External APIs are mocked in this sample. Leave these commented unless replacing mocks with real services.
# SF113_API_URL=http://localhost:9001/api
# CULTAS_API_URL=http://localhost:9002/api
# AI_SEARCH_ENDPOINT=https://your-search-service.search.windows.net
# AI_SEARCH_API_KEY=your_search_api_key_here

# Service Configuration
HOST=0.0.0.0
PORT=8001
LOG_LEVEL=INFO

# Voice Configuration
VOICE_NAME=ja-JP-NanamiNeural
VOICE_TEMPERATURE=0.7
TURN_DETECTION_THRESHOLD=0.5

# Call Logs
CALL_LOGS_DIR=./logs/calls
