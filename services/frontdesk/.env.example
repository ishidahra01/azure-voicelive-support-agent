# Frontdesk Service Environment Variables

# Azure Voice Live API
VOICE_LIVE_ENDPOINT=https://your-region.api.cognitive.microsoft.com/voice
# Leave blank to use Microsoft Entra ID via DefaultAzureCredential.
VOICE_LIVE_API_KEY=
VOICE_LIVE_MODEL=gpt-realtime

# Desk Services. Only faultdesk is implemented in this sample; leave future desks commented.
FAULT_DESK_WS_URL=ws://localhost:8001/ws/desk
# BILLING_DESK_WS_URL=ws://localhost:8002/ws/desk
# GENERAL_DESK_WS_URL=ws://localhost:8003/ws/desk

# Service Configuration
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Voice Configuration
VOICE_NAME=ja-JP-NanamiNeural
VOICE_TEMPERATURE=0.7
TURN_DETECTION_THRESHOLD=0.5
